<div class="quick-stats-dashlet" style="padding: 12px;">
    <table width="100%" cellpadding="8" cellspacing="0">
        <tr>
            <td align="center" style="border-right: 1px solid #ddd;">
                <div style="font-size: 2em; font-weight: bold; color: #333;">{$stats.contacts}</div>
                <div style="font-size: 0.85em; color: #888; text-transform: uppercase; letter-spacing: 0.05em;">Contacts</div>
            </td>
            <td align="center" style="border-right: 1px solid #ddd;">
                <div style="font-size: 2em; font-weight: bold; color: #333;">{$stats.accounts}</div>
                <div style="font-size: 0.85em; color: #888; text-transform: uppercase; letter-spacing: 0.05em;">Accounts</div>
            </td>
            <td align="center" style="border-right: 1px solid #ddd;">
                <div style="font-size: 2em; font-weight: bold; color: #e07b00;">{$stats.open_cases}</div>
                <div style="font-size: 0.85em; color: #888; text-transform: uppercase; letter-spacing: 0.05em;">Open Cases</div>
            </td>
            <td align="center">
                <div style="font-size: 2em; font-weight: bold; color: #2a7a2a;">{$stats.active_opportunities}</div>
                <div style="font-size: 0.85em; color: #888; text-transform: uppercase; letter-spacing: 0.05em;">Active Opportunities</div>
            </td>
        </tr>
    </table>
</div>
